# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # backend only — never ship to client
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Upstash Redis ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=Axxx...

# ── Google Maps ───────────────────────────────────────────────
# Enable: Maps JavaScript API + Directions API in Google Cloud Console
# https://console.cloud.google.com/apis/library
GOOGLE_MAPS_API_KEY=

# ── Mapbox (legacy — replaced by Google Maps) ─────────────────
MAPBOX_ACCESS_TOKEN=pk.eyJ...

# ── TSA API ───────────────────────────────────────────────────
# Get your key at https://www.tsawaittimes.com/register (7-day free trial)
# Leave blank to use realistic mock data instead
TSA_API_KEY=

# ── FlightAware AeroAPI (primary flight tracking) ─────────────
# Best for US domestic flights — FAA data, live position, delay programs
# https://www.flightaware.com/commercial/aeroapi/
# Personal tier: $0 ($5 free credit/month), Standard: $100/month
FLIGHTAWARE_API_KEY=

# ── AviationStack (flight tracking fallback + departures count) ─
# Global coverage fallback for flight-status; used by /api/departures
# for scheduled departure counts per airport
# https://aviationstack.com — free tier: 500 req/month
AVIATIONSTACK_API_KEY=

# ── Mobile API base ───────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://swiftclear-api.vercel.app
